rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "trimlinedev@gmail.com";
    }

    function hasBarberRole(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.roles.hasAny(["barber"]);
    }

    function isBarber(barberId) {
      return isSelf(barberId) && hasBarberRole(barberId);
    }

    function isBookingClient() {
      return signedIn() && resource.data.clientUserId == request.auth.uid;
    }

    function isBookingBarber() {
      return signedIn() && resource.data.barberId == request.auth.uid && hasBarberRole(request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();

      allow create: if isSelf(userId)
        && request.resource.data.roles == ["client"]
        && request.resource.data.activeMode == "client";

      allow update: if isAdmin()
        || (isSelf(userId) && (
          (
            request.resource.data.roles == resource.data.roles
            && request.resource.data.activeMode in resource.data.roles
          )
          ||
          (
            !resource.data.roles.hasAny(["barber"])
            && request.resource.data.roles.hasAny(["barber"])
            && request.resource.data.roles.size() == resource.data.roles.size() + 1
            && request.resource.data.activeMode == "barber"
            && getAfter(/databases/$(database)/documents/barberAccess/$(userId)).data.uid == userId
          )
        ));

      allow delete: if isSelf(userId) || isAdmin();
    }

    match /barberInvites/{inviteId} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.used == false
        && request.resource.data.revoked == false
        && request.resource.data.expiresAt > request.time;

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.used == false
          && resource.data.revoked == false
          && resource.data.expiresAt > request.time
          && request.resource.data.used == true
          && request.resource.data.usedBy == request.auth.uid
          && request.resource.data.usedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "used", "usedBy", "usedAt"
          ])
          && getAfter(/databases/$(database)/documents/barberAccess/$(request.auth.uid)).data.inviteId == inviteId
        );

      allow delete: if isAdmin();
    }

    match /barberAccess/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId)
        && request.resource.data.uid == userId
        && request.resource.data.inviteId is string
        && request.resource.data.grantedAt == request.time
        && getAfter(/databases/$(database)/documents/barberInvites/$(request.resource.data.inviteId)).data.used == true
        && getAfter(/databases/$(database)/documents/barberInvites/$(request.resource.data.inviteId)).data.usedBy == userId;
      allow update, delete: if isAdmin();
    }

    match /barbers/{barberId} {
      allow read: if signedIn();
      allow create, update, delete: if isBarber(barberId) || isAdmin();
    }

    match /clients/{clientId} {
      allow create: if isBarber(request.resource.data.barberId);
      allow read, update, delete: if isBarber(resource.data.barberId);
    }

    match /cuts/{cutId} {
      allow create: if isBarber(request.resource.data.barberId);
      allow read, update, delete: if isBarber(resource.data.barberId);
    }

    match /appointments/{appointmentId} {
      allow create: if isBarber(request.resource.data.barberId);
      allow read, update, delete: if isBarber(resource.data.barberId);
    }

    match /bookingRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.clientUserId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.barberId is string
        && request.resource.data.clientName is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.keys().hasOnly([
          "barberId", "barberUsername", "barberName",
          "clientUserId", "clientName", "phone", "email",
          "service", "date", "time", "notes", "status", "createdAt"
        ]);

      allow read: if isBookingBarber() || isBookingClient();

      allow update: if isBookingBarber()
        && request.resource.data.barberId == resource.data.barberId
        && request.resource.data.clientUserId == resource.data.clientUserId
        && request.resource.data.date == resource.data.date
        && request.resource.data.time == resource.data.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status", "acceptedAt", "declinedAt", "cancelledAt",
          "cancelledBy", "declinedBy", "appointmentId", "linkedClientId"
        ]);

      allow delete: if isBookingBarber()
        || (isBookingClient() && resource.data.status != "accepted");
    }

    match /availabilitySlots/{slotId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.barberId is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.status in ["pending", "scheduled"]
        && (
          isBarber(request.resource.data.barberId) ||
          request.resource.data.clientUserId == request.auth.uid
        )
        && request.resource.data.keys().hasOnly([
          "barberId", "clientUserId", "date", "time",
          "status", "bookingRequestId", "appointmentId", "createdAt"
        ]);

      allow update: if signedIn()
        && (
          isBarber(resource.data.barberId) ||
          resource.data.clientUserId == request.auth.uid
        )
        && request.resource.data.barberId == resource.data.barberId
        && request.resource.data.clientUserId == resource.data.clientUserId
        && request.resource.data.date == resource.data.date
        && request.resource.data.time == resource.data.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status", "bookingRequestId", "appointmentId", "updatedAt"
        ]);

      allow delete: if signedIn()
        && (
          isBarber(resource.data.barberId) ||
          resource.data.clientUserId == request.auth.uid
        );
    }
  }
}
